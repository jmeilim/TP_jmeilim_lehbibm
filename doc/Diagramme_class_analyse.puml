@startuml
skinparam class {
  BackgroundColor #F5F5F5
  BorderColor #666666
  FontSize 12
}


class Univers {
  - eps, sig    : double
  - lx, ly      : double
  - rc, cellSize: double
  - nx, ny      : int
  + initialiserGrille()
  + updateCells()
  + addParticle(p : Particle)
  + getNbParticles() : int
  + getGrid()    : vector<Cellule>&
  + getParticles(): vector<Particle>&
}

class Particle {
  - position : Vector
  - vitesse  : Vector
  - force    : Vector
  - masse    : double
  - cat      : string
  + getPosition() : Vector&
  + getVitesse()  : Vector&
  + getMasse()    : double
  + isAlive()     : bool
  + getCat()      : string
  + setAlive(bool)
}


class Vector {
  - x, y, z : double
  + operator+(Vector)
  + operator-(Vector)
  + operator*(double)
  + operator+=(Vector)
  + operator[](int)
  + setX(double), setY(double)
}

class Cellule {
  - center    : Vector
  - particles : vector<int>
  + getCenter()    : Vector
  + getParticles() : vector<int>
}


class Forces << service >> {
  + computeForce(p, ps, rc, grid, cellSize, nx, ny) : Vector
  + computeGravity(p, G) : Vector
  + forceMurBas(p, eps, sig) : Vector
  + U(r, eps, sig) : double
}

class Boundary << service >> {
  + conditionLimites(p, Lx, Ly) : bool
  + réflexion()
  + absorption()
  + périodique()
}

class Stromer << service >> {
  - dt        : double
  - Ec_target : double
  + stromer(u, Fo, dt, iter)
  ' β = sqrt(Ec_target / Ec)
  ' appliqué toutes 1000 itérations
  ' uniquement sur cat == "rect"
}


Univers  "1" *-- "1..*" Particle  : contient
Univers  "1" *-- "1..*" Cellule   : contient

Particle "1" *-- "3"    Vector    : position\nvitesse\nforce

Cellule  "1" o-- "*"    Particle  : réf. par indice

Forces   ..> Particle : utilise
Forces   ..> Cellule  : utilise
Boundary ..> Particle : utilise
Stromer  ..> Univers  : utilise
Stromer  ..> Forces   : appelle computeForce()
Stromer  ..> Boundary : appelle conditionLimites()
@enduml